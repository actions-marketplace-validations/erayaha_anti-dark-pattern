{
  "name": "anti-dark-pattern",
  "version": "1.0.0",
  "description": "Automated CI/CD dark pattern linter for front-end codebases.",
  "main": "dist/src/index.js",
  "bin": {
    "anti-dark-pattern": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .ts,.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^8.57.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.5"
  }
}
